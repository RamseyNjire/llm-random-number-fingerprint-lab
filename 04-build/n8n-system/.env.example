# n8n API
# Always use HTTPS in automation scripts to avoid POST/import redirect issues.
N8N_BASE_URL=https://your-n8n-domain.example.com
N8N_API_KEY=replace_me
N8N_PAGE_SIZE=200

# Experiment resources
RANDOM_NUMBER_FINGERPRINT_SHEET_ID=replace_with_your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json

# n8n credential IDs used by scripts/deploy-random-number-workflow.py
# Create these credentials inside n8n first, then paste the credential IDs here.
N8N_GOOGLE_SHEETS_CREDENTIAL_ID=
N8N_GOOGLE_SHEETS_CREDENTIAL_NAME=Google Sheets account
N8N_OPENROUTER_CREDENTIAL_ID=
N8N_OPENROUTER_CREDENTIAL_NAME=OpenRouter account

# Optional reporting / routing defaults
ALERT_EMAIL_TO=ops@example.com
DEFAULT_TIMEZONE=UTC

# Sync monitor webhook (used by scripts/run-sync.sh)
SYNC_MONITOR_WEBHOOK_URL=
SYNC_MONITOR_AUTH_TOKEN=
